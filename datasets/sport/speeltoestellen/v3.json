{
  "id": "speeltoestellen",
  "title": "Sport- en speeltoestellen",
  "type": "table",
  "version": "3.0.0",
  "status": "under_development",
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "schema",
      "id"
    ],
    "display": "naam",
    "properties": {
      "schema": {
        "$ref": "https://schemas.data.amsterdam.nl/schema@v4.0.0#/definitions/schema"
      },
      "id": {
        "type": "integer",
        "description": "Unieke aanduiding van het speeltoestel.",
        "title": "Speeltoestel ID"
      },
      "geometry": {
        "$ref": "https://geojson.org/schema/Point.json",
        "description": "Puntgeometrie van het speeltoestel.",
        "title": "Speeltoestel geometrie"
      },
      "naam": {
        "type": "string",
        "description": "Naam van het speeltoestel.",
        "title": "Speeltoestel naam"
      },
      "type": {
        "type": "string",
        "description": "Het type toestel zoals gedefinieerd in IMBOR.",
        "title": "Type speeltoestel"
      },
      "typeActiviteit": {
        "type": "string",
        "description": "Het type activiteit zoals spelen of voetbal, afgeleid uit het type en/of de naam van het sport- of speeltoestel.",
        "title": "Type activiteit voor speeltoestel"
      }
    }
  }
}
